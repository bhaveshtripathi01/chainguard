# Vercel Ignore Configuration

# Node modules (will be installed during build)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (use Vercel environment variables instead)
.env
.env.local
.env.*.local

# Git files
.git
.gitignore

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode
.idea
*.swp
*.swo

# Blockchain artifacts
blockchain/cache/
blockchain/artifacts/

# Test files
*.test.js
*.spec.js

# Temporary files
backend/temp/
